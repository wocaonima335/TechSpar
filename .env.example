# LLM (OpenAI-compatible endpoint)
API_BASE=https://your-llm-api-base/v1
API_KEY=sk-your-api-key
MODEL=your-model-name

# Auth / bootstrap
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=120
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-initial-admin-password

# Embedding — API mode (OpenAI-compatible, e.g. SiliconFlow / OpenAI)
# Leave EMBEDDING_API_BASE empty to use local HuggingFace model instead
EMBEDDING_API_BASE=https://your-embedding-api-base/v1
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=BAAI/bge-m3
